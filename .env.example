# Your phone cannot call http://localhost:3000 on your computer.
# Use your computer LAN IP from Next terminal, for example:
# EXPO_PUBLIC_API_BASE_URL=http://100.110.142.100:3000
EXPO_PUBLIC_API_BASE_URL=http://YOUR_COMPUTER_IP:3000

# If true, the app will use local mock replies instead of /api/chat.
EXPO_PUBLIC_USE_MOCK=false
